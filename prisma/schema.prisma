generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                    Int      @id @default(autoincrement())
  fullAddress           String
  sector                String
  city                  String?

  groundFloorArea       Float
  hasBasement           Boolean
  basementArea          Float?
  hasUpperFloor         Boolean
  upperFloorArea        Float?
  hasApartment          Boolean
  apartmentArea         Float?

  occupancyStatus       String
  annualRentExclCharges Float?
  tenantActivity        String?
  leaseEndDate          DateTime?
  annualCharges         Float?
  propertyTax           Float?

  commercialLeaseFile   String?
  propertyTaxFile       String?
  plansFile             String?
  photosFile            String?
  otherDocumentsFile    String?

  additionalInfo        String?

  ownerName             String
  ownerPhone            String
  ownerEmail            String

  createdAt             DateTime @default(now())
}
