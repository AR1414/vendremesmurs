generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                    Int      @id @default(autoincrement())

  fullAddress           String
  sector                String
  city                  String?

  groundFloorArea       Float
  hasBasement           String
  basementArea          Float?
  hasUpperFloor         String
  upperFloorArea        Float?
  hasApartment          String
  apartmentArea         Float?

  occupancyStatus       String
  isBusinessAlsoForSale String?
  annualRentExclCharges Float?
  tenantActivity        String?
  leaseEndDate          DateTime?
  annualCharges         Float?
  propertyTax           Float?

  additionalInfo        String?

  ownerName             String
  ownerPhone            String
  ownerEmail            String

  commercialLeaseFile   String?
  propertyTaxFile       String?
  plansFile             String?
  photosFile            String?
  otherDocumentsFile    String?

  createdAt             DateTime @default(now())
}
